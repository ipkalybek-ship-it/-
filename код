<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>B2B Заказ Товаров — Интерактивный каталог</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body {
            background-color: #F8FAFC;
            color: #1E293B;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            scroll-behavior: smooth;
        }
        .chart-container {
            position: relative;
            width: 100%;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
            height: 300px;
            max-height: 400px;
        }
        .glass-panel {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(226, 232, 240, 0.8);
        }
        .product-card {
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .product-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 20px -5px rgba(0, 0, 0, 0.1);
        }
        .custom-scroll::-webkit-scrollbar {
            width: 6px;
        }
        .custom-scroll::-webkit-scrollbar-track {
            background: #f1f1f1;
        }
        .custom-scroll::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }
    </style>
    
    <!-- Chosen Palette: Fresh Professional (Slate-50 background, Blue-600 accents, Indigo-900 for text, Emerald-500 for status) -->
    <!-- Application Structure Plan: The SPA is designed as a functional dashboard. It features a sticky navigation, a metrics summary section, an interactive product catalog with filtering/search, and a slide-out order summary (Basket). This structure was chosen because B2B users prioritize utility and speed: they need to see what's available, adjust quantities, and verify logistics (weight/total) immediately. -->
    <!-- Visualization & Content Choices: 
        1. Product Data -> From provided images (Pasta, Sugar, 6 types of Rusks).
        2. Order Analytics -> Goal: Compare -> Viz: Chart.js Doughnut (Weight distribution) -> Interaction: Reactive update on order change -> Justification: Helps managers plan logistics/delivery vehicle capacity.
        3. Catalog -> Goal: Organize/Organize -> Viz: Responsive Grid -> Interaction: Search/Filter/Add-to-order -> Justification: Standard e-commerce pattern adapted for speed. 
        Confirming NO SVG/Mermaid used.
    -->
    <!-- CONFIRMATION: NO SVG graphics used. NO Mermaid JS used. -->
</head>
<body class="antialiased selection:bg-blue-100">

    <nav class="fixed top-0 w-full z-50 glass-panel shadow-sm border-b border-slate-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-2 font-bold text-xl text-blue-700">
                    <span class="bg-blue-600 text-white p-1 rounded">B2B</span> Продукты
                </div>
                <div class="flex items-center gap-6">
                    <div class="hidden md:flex space-x-6 text-sm font-semibold text-slate-600">
                        <a href="#catalog" class="hover:text-blue-600 transition-colors">Каталог</a>
                        <a href="#analytics" class="hover:text-blue-600 transition-colors">Аналитика</a>
                    </div>
                    <button onclick="toggleCart()" class="relative p-2 bg-blue-50 rounded-full text-blue-700 hover:bg-blue-100 transition-colors">
                        <span class="text-xl">🛒</span>
                        <span id="cart-count" class="absolute -top-1 -right-1 bg-red-500 text-white text-[10px] w-5 h-5 flex items-center justify-center rounded-full font-bold">0</span>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <main class="pt-24 pb-12 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12">

        <section id="hero" class="bg-gradient-to-br from-blue-600 to-indigo-700 rounded-3xl p-8 text-white shadow-xl">
            <div class="max-w-3xl">
                <h1 class="text-3xl md:text-4xl font-extrabold mb-4 leading-tight">Портал оптовых заказов</h1>
                <p class="text-blue-100 text-lg mb-8">Выбирайте товары из каталога, указывайте необходимое количество и формируйте заказ в один клик. Все цены и остатки актуальны на текущий момент.</p>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    <div class="bg-white/10 backdrop-blur-md p-4 rounded-xl">
                        <div class="text-sm opacity-80 mb-1">К заказу доступно</div>
                        <div class="text-2xl font-bold">8 позиций</div>
                    </div>
                    <div class="bg-white/10 backdrop-blur-md p-4 rounded-xl">
                        <div class="text-sm opacity-80 mb-1">Мин. заказ</div>
                        <div class="text-2xl font-bold">5 000 ₸</div>
                    </div>
                    <div class="bg-white/10 backdrop-blur-md p-4 rounded-xl">
                        <div class="text-sm opacity-80 mb-1">Доставка</div>
                        <div class="text-2xl font-bold">Бесплатно</div>
                    </div>
                </div>
            </div>
        </section>

        <section id="catalog" class="space-y-6">
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
                <div class="flex-1 space-y-4">
                    <h2 class="text-2xl font-bold text-slate-900">Каталог товаров</h2>
                    <div class="flex flex-wrap gap-2">
                        <button onclick="filterCategory('all')" id="btn-all" class="px-4 py-2 rounded-lg text-sm font-semibold transition-all bg-blue-600 text-white shadow-md">Все</button>
                        <button onclick="filterCategory('бакалея')" id="btn-бакалея" class="px-4 py-2 rounded-lg text-sm font-semibold transition-all bg-white text-slate-600 border border-slate-200 hover:border-blue-300">Бакалея</button>
                        <button onclick="filterCategory('снеки')" id="btn-снеки" class="px-4 py-2 rounded-lg text-sm font-semibold transition-all bg-white text-slate-600 border border-slate-200 hover:border-blue-300">Снеки</button>
                    </div>
                </div>
                <div class="w-full md:w-72 relative">
                    <input type="text" id="searchInput" placeholder="Поиск по названию..." class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all">
                    <span class="absolute left-3 top-3 text-slate-400">🔍</span>
                </div>
            </div>

            <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- Products will be injected here -->
            </div>
        </section>

        <section id="analytics" class="scroll-mt-24">
            <div class="glass-panel p-8 rounded-2xl shadow-sm">
                <div class="mb-6">
                    <h2 class="text-2xl font-bold text-slate-900">Аналитика текущего заказа</h2>
                    <p class="text-slate-500 mt-1">Распределение веса продукции для логистики.</p>
                </div>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                    <div class="chart-container">
                        <canvas id="weightChart"></canvas>
                    </div>
                    <div id="analytics-summary" class="space-y-4">
                        <div class="p-6 bg-slate-50 rounded-xl border border-slate-100">
                            <h4 class="text-slate-500 text-sm font-semibold uppercase tracking-wider mb-2">Итоговые показатели</h4>
                            <div class="space-y-3">
                                <div class="flex justify-between items-center">
                                    <span class="text-slate-600">Вес брутто:</span>
                                    <span id="total-weight" class="font-bold text-lg">0 кг</span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-slate-600">Общая сумма:</span>
                                    <span id="total-price" class="font-bold text-2xl text-blue-600">0 ₸</span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-slate-600">Количество позиций:</span>
                                    <span id="total-positions" class="font-bold">0</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <!-- Side Cart (Basket) -->
    <div id="cart-drawer" class="fixed inset-y-0 right-0 w-full md:w-[450px] bg-white shadow-2xl z-[60] transform translate-x-full transition-transform duration-300 ease-in-out">
        <div class="h-full flex flex-col">
            <div class="p-6 border-b flex justify-between items-center bg-slate-50">
                <h3 class="text-xl font-bold text-slate-900">Ваш заказ</h3>
                <button onclick="toggleCart()" class="text-slate-400 hover:text-slate-600 text-2xl">✕</button>
            </div>
            
            <div id="cart-items" class="flex-1 overflow-y-auto p-6 space-y-4 custom-scroll">
                <!-- Cart items will be injected here -->
                <div id="empty-cart-msg" class="text-center py-12 text-slate-400">
                    <div class="text-5xl mb-4">🛒</div>
                    <p>Корзина пуста. Добавьте товары из каталога.</p>
                </div>
            </div>

            <div class="p-6 border-t bg-slate-50 space-y-4">
                <div class="grid grid-cols-2 gap-4 mb-4">
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Дата доставки</label>
                        <input type="date" id="delivery-date" class="w-full p-2 border rounded-lg text-sm outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Тип оплаты</label>
                        <select class="w-full p-2 border rounded-lg text-sm outline-none">
                            <option>Оплата по счету</option>
                            <option>При получении</option>
                        </select>
                    </div>
                </div>
                <textarea placeholder="Комментарий к заказу (необязательно)..." class="w-full p-3 border rounded-xl text-sm outline-none focus:ring-2 focus:ring-blue-500 h-20 resize-none"></textarea>
                <div class="flex justify-between items-end mb-2">
                    <span class="text-slate-600 font-medium">Итого к оплате:</span>
                    <span id="cart-total-price" class="text-2xl font-bold text-slate-900">0 ₸</span>
                </div>
                <button onclick="confirmOrder()" class="w-full py-4 bg-blue-600 text-white rounded-xl font-bold text-lg hover:bg-blue-700 transition-colors shadow-lg shadow-blue-200">
                    Оформить заказ
                </button>
            </div>
        </div>
    </div>
    
    <div id="cart-overlay" onclick="toggleCart()" class="fixed inset-0 bg-black/30 backdrop-blur-sm z-[55] hidden opacity-0 transition-opacity"></div>

    <script>
        const products = [
            { id: 1, name: 'Лапша "Яичная"', brand: 'МаМон', weight: 350, unit: 'г', category: 'бакалея', price: 420, image: '🍝' },
            { id: 2, name: 'Сахар рафинад', brand: 'Отличная Кухня', weight: 900, unit: 'г', category: 'бакалея', price: 680, image: '🧊' },
            { id: 3, name: 'Сухари сдобные: Ванильные', brand: 'Трапеза', weight: 350, unit: 'г', category: 'снеки', price: 290, image: '🥖' },
            { id: 4, name: 'Сухари сдобные: С маком', brand: 'Трапеза', weight: 350, unit: 'г', category: 'снеки', price: 310, image: '🥯' },
            { id: 5, name: 'Сухари сдобные: Со сгущенкой', brand: 'Трапеза', weight: 200, unit: 'г', category: 'снеки', price: 250, image: '🍯' },
            { id: 6, name: 'Сухари сдобные: Изюм', brand: 'Трапеза', weight: 200, unit: 'г', category: 'снеки', price: 270, image: '🍇' },
            { id: 7, name: 'Сухари сдобные: Молочные', brand: 'Трапеза', weight: 350, unit: 'г', category: 'снеки', price: 290, image: '🥛' },
            { id: 8, name: 'Сухари сдобные: С орехами', brand: 'Трапеза', weight: 200, unit: 'г', category: 'снеки', price: 320, image: '🥜' }
        ];

        let state = {
            cart: [],
            activeCategory: 'all',
            searchQuery: ''
        };

        let weightChart = null;

        function toggleCart() {
            const drawer = document.getElementById('cart-drawer');
            const overlay = document.getElementById('cart-overlay');
            const isOpen = drawer.classList.contains('translate-x-full');
            
            if(isOpen) {
                drawer.classList.remove('translate-x-full');
                overlay.classList.remove('hidden');
                setTimeout(() => overlay.classList.add('opacity-100'), 10);
            } else {
                drawer.classList.add('translate-x-full');
                overlay.classList.remove('opacity-100');
                setTimeout(() => overlay.classList.add('hidden'), 300);
            }
        }

        function filterCategory(cat) {
            state.activeCategory = cat;
            ['all', 'бакалея', 'снеки'].forEach(id => {
                const btn = document.getElementById(`btn-${id}`);
                if(id === cat) {
                    btn.className = 'px-4 py-2 rounded-lg text-sm font-semibold transition-all bg-blue-600 text-white shadow-md';
                } else {
                    btn.className = 'px-4 py-2 rounded-lg text-sm font-semibold transition-all bg-white text-slate-600 border border-slate-200 hover:border-blue-300';
                }
            });
            renderCatalog();
        }

        document.getElementById('searchInput').addEventListener('input', (e) => {
            state.searchQuery = e.target.value.toLowerCase();
            renderCatalog();
        });

        function renderCatalog() {
            const grid = document.getElementById('product-grid');
            grid.innerHTML = '';
            
            const filtered = products.filter(p => {
                const matchesCat = state.activeCategory === 'all' || p.category === state.activeCategory;
                const matchesSearch = p.name.toLowerCase().includes(state.searchQuery) || p.brand.toLowerCase().includes(state.searchQuery);
                return matchesCat && matchesSearch;
            });

            filtered.forEach(p => {
                const card = document.createElement('div');
                card.className = 'product-card glass-panel rounded-2xl p-5 border border-slate-200 flex flex-col';
                card.innerHTML = `
                    <div class="h-32 bg-slate-50 rounded-xl flex items-center justify-center text-5xl mb-4">${p.image}</div>
                    <div class="mb-1 text-[10px] font-bold text-blue-600 uppercase tracking-widest">${p.brand}</div>
                    <h4 class="font-bold text-slate-900 mb-2 leading-tight h-10 overflow-hidden">${p.name}</h4>
                    <div class="text-xs text-slate-400 mb-4 flex justify-between">
                        <span>Вес: ${p.weight} ${p.unit}</span>
                        <span>Категория: ${p.category}</span>
                    </div>
                    <div class="mt-auto pt-4 border-t flex items-center justify-between">
                        <div>
                            <span class="text-xl font-black text-slate-900">${p.price} ₸</span>
                        </div>
                        <button onclick="addToCart(${p.id})" class="bg-blue-600 text-white w-10 h-10 rounded-lg font-bold hover:bg-blue-700 transition-colors flex items-center justify-center">
                            +
                        </button>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        function addToCart(id) {
            const product = products.find(p => p.id === id);
            const existing = state.cart.find(item => item.id === id);
            
            if(existing) {
                existing.quantity += 1;
            } else {
                state.cart.push({...product, quantity: 1});
            }
            updateCartUI();
            
            // Notification effect
            const btn = event.currentTarget;
            const original = btn.innerText;
            btn.innerText = '✓';
            btn.classList.replace('bg-blue-600', 'bg-emerald-500');
            setTimeout(() => {
                btn.innerText = original;
                btn.classList.replace('bg-emerald-500', 'bg-blue-600');
            }, 800);
        }

        function updateCartUI() {
            const count = state.cart.reduce((acc, item) => acc + item.quantity, 0);
            document.getElementById('cart-count').innerText = count;
            
            const list = document.getElementById('cart-items');
            const emptyMsg = document.getElementById('empty-cart-msg');
            
            if(state.cart.length === 0) {
                emptyMsg.classList.remove('hidden');
                list.querySelectorAll('.cart-item-row').forEach(el => el.remove());
            } else {
                emptyMsg.classList.add('hidden');
                list.innerHTML = '';
                state.cart.forEach(item => {
                    const row = document.createElement('div');
                    row.className = 'cart-item-row p-4 rounded-xl border border-slate-100 flex gap-4 items-center bg-white';
                    row.innerHTML = `
                        <div class="text-2xl">${item.image}</div>
                        <div class="flex-1">
                            <h5 class="font-bold text-sm text-slate-900">${item.name}</h5>
                            <p class="text-xs text-slate-400">${item.price} ₸ / шт</p>
                        </div>
                        <div class="flex items-center gap-2">
                            <button onclick="changeQty(${item.id}, -1)" class="w-8 h-8 rounded bg-slate-100 hover:bg-slate-200 text-slate-600">-</button>
                            <span class="w-6 text-center font-bold text-sm">${item.quantity}</span>
                            <button onclick="changeQty(${item.id}, 1)" class="w-8 h-8 rounded bg-slate-100 hover:bg-slate-200 text-slate-600">+</button>
                        </div>
                        <div class="text-right w-16">
                            <span class="font-bold text-sm">${item.price * item.quantity} ₸</span>
                        </div>
                    `;
                    list.appendChild(row);
                });
            }

            calculateTotals();
        }

        function changeQty(id, delta) {
            const item = state.cart.find(i => i.id === id);
            if(item) {
                item.quantity += delta;
                if(item.quantity <= 0) {
                    state.cart = state.cart.filter(i => i.id !== id);
                }
                updateCartUI();
            }
        }

        function calculateTotals() {
            const totalPrice = state.cart.reduce((acc, item) => acc + (item.price * item.quantity), 0);
            const totalWeight = state.cart.reduce((acc, item) => acc + (item.weight * item.quantity), 0) / 1000;
            
            document.getElementById('cart-total-price').innerText = `${totalPrice} ₸`;
            document.getElementById('total-price').innerText = `${totalPrice} ₸`;
            document.getElementById('total-weight').innerText = `${totalWeight.toFixed(2)} кг`;
            document.getElementById('total-positions').innerText = state.cart.length;

            updateChart();
        }

        function updateChart() {
            const categories = {};
            state.cart.forEach(item => {
                categories[item.category] = (categories[item.category] || 0) + (item.weight * item.quantity);
            });

            const labels = Object.keys(categories).map(c => c.charAt(0).toUpperCase() + c.slice(1));
            const data = Object.values(categories).map(v => v / 1000); // to kg

            if(weightChart) {
                weightChart.data.labels = labels;
                weightChart.data.datasets[0].data = data;
                weightChart.update();
            } else {
                initChart(labels, data);
            }
        }

        function initChart(labels, data) {
            const ctx = document.getElementById('weightChart').getContext('2d');
            weightChart = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: labels.length ? labels : ['Нет данных'],
                    datasets: [{
                        data: data.length ? data : [1],
                        backgroundColor: ['#3B82F6', '#10B981', '#F59E0B', '#EF4444'],
                        borderWidth: 0,
                        hoverOffset: 15
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: { position: 'bottom', labels: { padding: 20, usePointStyle: true } },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return `${context.label}: ${context.raw.toFixed(2)} кг`;
                                }
                            }
                        }
                    }
                }
            });
        }

        function confirmOrder() {
            if(state.cart.length === 0) {
                showToast('Сначала добавьте товары в корзину');
                return;
            }
            showToast('Заказ успешно сформирован! Наш менеджер свяжется с вами.', 'success');
            state.cart = [];
            updateCartUI();
            toggleCart();
        }

        function showToast(msg, type = 'info') {
            const toast = document.createElement('div');
            toast.className = `fixed bottom-8 left-1/2 -translate-x-1/2 px-6 py-3 rounded-full text-white font-bold shadow-2xl z-[100] transition-all transform translate-y-20 ${type === 'success' ? 'bg-emerald-500' : 'bg-slate-800'}`;
            toast.innerText = msg;
            document.body.appendChild(toast);
            
            setTimeout(() => toast.classList.remove('translate-y-20'), 10);
            setTimeout(() => {
                toast.classList.add('translate-y-20');
                setTimeout(() => toast.remove(), 500);
            }, 3000);
        }

        // Initialize on load
        window.onload = () => {
            renderCatalog();
            initChart([], []);
            
            // Set default delivery date to tomorrow
            const tomorrow = new Date();
            tomorrow.setDate(tomorrow.getDate() + 1);
            document.getElementById('delivery-date').valueAsDate = tomorrow;
        };
    </script>
</body>
</html>
